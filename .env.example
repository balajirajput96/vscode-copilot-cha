# This is an example file. Copy this to a new file named .env
# and fill in your actual credentials. This .env file is ignored by git.

# --- GitHub ---
# A secret key used to verify that webhooks are coming from GitHub.
# Create a random string for this.
GITHUB_WEBHOOK_SECRET="YOUR_GITHUB_WEBHOOK_SECRET"

# --- Jira ---
# Your Jira domain (e.g., your-company.atlassian.net)
JIRA_DOMAIN="YOUR_JIRA_DOMAIN"
# Your Jira username or email
JIRA_USERNAME="YOUR_JIRA_USERNAME"
# Your Jira API token (NOT your password)
JIRA_API_TOKEN="YOUR_JIRA_API_TOKEN"
# The project key for the Jira project where issues will be created (e.g., "PROJ")
JIRA_PROJECT_KEY="YOUR_JIRA_PROJECT_KEY"